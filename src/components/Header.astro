---
import { NAV, SITE } from '../consts';
import ThemeToggle from './ThemeToggle.astro';
const path = Astro.url.pathname;
---
<header class="sticky top-0 z-40 backdrop-blur bg-paper/70 dark:bg-ink/70 border-b hr-soft">
  <div class="container-wide flex items-center justify-between h-14">
    <a href="/" class="font-semibold tracking-tight no-underline">{SITE.name}</a>
    <nav class="flex items-center gap-5 text-sm">
      {NAV.map((n) => (
        <a
          href={n.href}
          class={`no-underline hover:text-accent ${path === n.href ? 'text-accent' : 'opacity-80'}`}
        >{n.label}</a>
      ))}
      <ThemeToggle />
    </nav>
  </div>
</header>
