---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Not found" description="Page not found." noindex={true}>
  <section class="container-prose py-32 text-center">
    <p class="text-xs tracking-[0.2em] uppercase opacity-60 mb-4">404</p>
    <h1 class="text-4xl mb-4">This page is quieter than the rest.</h1>
    <p class="opacity-80 mb-8">The page you were looking for does not exist — or perhaps never did.</p>
    <a href="/" class="btn-primary">Back home</a>
  </section>
</Layout>
